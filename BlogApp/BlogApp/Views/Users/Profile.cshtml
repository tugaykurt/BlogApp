@model User
@{
    ViewData["Title"] = "Profile";
}
<div class="row">
    <div class="col-md-2">
        <div class="bg-white p-4">
            <img src="/img/@Model.Image" class="img-fluid" alt="@Model.UserName" />
        </div>
        <div class="bg-white p-2">
            <h6><i class="bi bi-person-circle"></i> @Model.UserName</h6>
        </div>
    </div>
    <div class="col-md-10">
        <div class="bg-white p-4">
            <table class="table">
                <tr class="border-bottom">
                    <td><h3>@Model.Name</h3></td>
                    <td style="width:200px"><a asp-action="Edit" asp-route-id="@Model.UserId" class="btn btn-warning">Edit Profile</a></td>
                </tr>
            </table>
            <div id="Contents">
                <h5 class="my-4">Published Contents</h5>
                <div>
                    @foreach (var post in Model.Posts)
                    {
                      <div class="my-4 d-flex border-bottom">
                            <a href="/post/@post.Url" class="icon-link-hover"><img src="/img/@post.Image" class="postpicture rounded-circle me-3" /></a>
                          <div>
                              <div class="mb-2 d-flex">
                                    <h5 class="me-2"><a href="/post/@post.Url" class="link-opacity-10-hover">@post.Title</a></h5>
                              </div>
                                <p><a href="/post/@post.Url" class="link-opacity-10-hover">@post.Description</a></p>
                          </div>
                      </div>
                    }
                </div>
            </div>
            <div id="Comments">
                <h5 class="my-4">Comments</h5>
                <ul class="list-group">
                    @foreach (var comment in Model.Comments)
                    {
                        <li class="list-group-item"><i class="bi bi-chat-right-text-fill"></i> @comment.Text <i><u>[@comment.Post.Title]</u></i></li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

