@model PostDeleteViewModel
@{
    ViewData["Title"] = "PostDelete";
}

<div class="row">
    <div class="col-12">
        <div class="bg-white p-4">
            <p class="my-3">Are you sure you want to delete the post with the @Model.Title title?</p>
            <form asp-action="PostDelete" method="post">
                <input type="hidden" asp-for="PostId" />
                <button type="submit" class="btn btn-danger">Yes</button>
                <a asp-action="List" class="btn btn-secondary">No</a>
            </form>
        </div>
    </div>
</div>

