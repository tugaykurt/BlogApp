@model List<Post>
@{
    ViewData["Title"] = "List";
}
<div class="row">
    <div class="col-12">
        <h2>Post List</h2>
        <a href="/Posts/Create" class="btn btn-primary">New Post</a>
        <hr />
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th style="width:200px">Image</th>
                    <th>Id</th>
                    <th>Title</th>
                    <th>IsActive</th>
                    <th style="width:125px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in Model)
                {
                    <tr>
                        <td><a href="/post/@post.Url" class="link-opacity-10-hover"><img src="/img/@post.Image" class="img-fluid rounded-3 icon-link-hover" /></a></td>
                        <td>@post.PostId</td>
                        <td><a href="/post/@post.Url" class="link-opacity-10-hover">@post.Title</a></td>
                        <td>@post.IsActive</td>
                        <td>
                            <a href="/Posts/Edit/@post.PostId" class="btn btn-sm btn-warning align-items-center">Edit</a>
                            <a href="/posts/postdelete/@post.PostId" class="btn btn-sm btn-danger align-items-center">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

